---
import { Icon } from "astro-icon/components";
import SocialLinks from "~/components/SocialLinks.astro";
import { site } from "~/data/site";
---

<section id="about" class="relative overflow-hidden">
  <div aria-hidden="true" class="bg-grid pointer-events-none absolute inset-0 text-zinc-400 dark:text-zinc-500"></div>

  <div class="relative mx-auto max-w-5xl px-4 pb-16 pt-20 sm:px-6 sm:pt-28 lg:px-8 lg:pb-24">
    <div class="flex max-w-3xl flex-col gap-6">
      {
        site.status && (
          <div class="inline-flex w-fit items-center gap-2 rounded-full border border-zinc-200 bg-white/60 px-3 py-1 text-xs font-medium text-zinc-700 shadow-sm backdrop-blur dark:border-zinc-800 dark:bg-zinc-900/50 dark:text-zinc-300">
            <span class="relative flex size-2">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75" />
              <span class="relative inline-flex size-2 rounded-full bg-emerald-500" />
            </span>
            {site.status}
          </div>
        )
      }

      <h1
        class="text-4xl font-bold tracking-tight text-zinc-900 sm:text-5xl lg:text-6xl dark:text-white"
      >
        Hi, I'm <span class="text-accent-600 dark:text-accent-400">{site.name}</span>.
      </h1>

      <p class="text-lg text-zinc-600 sm:text-xl dark:text-zinc-300">
        <span class="font-medium text-zinc-900 dark:text-white">{site.role}</span>
        — {site.tagline}
      </p>

      <div class="flex items-center gap-2 text-sm text-zinc-500 dark:text-zinc-400">
        <Icon name="lucide:map-pin" class="size-4" aria-hidden="true" />
        <span>{site.location}</span>
      </div>

      <div class="mt-2 flex flex-wrap items-center gap-3">
        <a
          href="#projects"
          class="inline-flex items-center gap-1.5 rounded-md bg-accent-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-accent-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-500"
        >
          View projects
          <Icon name="lucide:arrow-down" class="size-4" aria-hidden="true" />
        </a>
        {
          site.resumeUrl && (
            <a
              href={site.resumeUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 rounded-md border border-zinc-300 bg-white px-4 py-2.5 text-sm font-semibold text-zinc-900 shadow-sm transition-colors hover:bg-zinc-50 dark:border-zinc-700 dark:bg-zinc-900 dark:text-white dark:hover:bg-zinc-800"
            >
              <Icon name="lucide:download" class="size-4" aria-hidden="true" />
              Download CV
            </a>
          )
        }
        <a
          href={`mailto:${site.email}`}
          class="inline-flex items-center gap-1.5 rounded-md px-3 py-2.5 text-sm font-semibold text-zinc-700 transition-colors hover:bg-zinc-100 dark:text-zinc-200 dark:hover:bg-zinc-800"
        >
          <Icon name="lucide:mail" class="size-4" aria-hidden="true" />
          Get in touch
        </a>
      </div>

      <SocialLinks class="mt-2 -ml-2" />
    </div>
  </div>
</section>
