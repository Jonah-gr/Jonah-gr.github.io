---
import { Icon } from "astro-icon/components";
import SectionHeading from "~/components/SectionHeading.astro";
import { skillGroups } from "~/data/skills";
---

<section id="skills" class="py-20 sm:py-24">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <SectionHeading
      eyebrow="Toolkit"
      title="Skills & technologies"
      description="The stack I reach for when shipping data and ML systems end-to-end."
    />

    <ul class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        skillGroups.map((group) => (
          <li class="group rounded-xl border border-zinc-200 bg-white p-5 shadow-sm transition-colors hover:border-accent-300 dark:border-zinc-800 dark:bg-zinc-950 dark:hover:border-accent-700">
            <div class="mb-3 flex items-center gap-2">
              <span class="inline-flex size-8 items-center justify-center rounded-md bg-accent-50 text-accent-700 dark:bg-accent-500/10 dark:text-accent-300">
                <Icon name={`lucide:${group.icon}`} class="size-4" aria-hidden="true" />
              </span>
              <h3 class="text-base font-semibold text-zinc-900 dark:text-white">{group.title}</h3>
            </div>
            <ul class="flex flex-wrap gap-1.5">
              {group.items.map((item) => (
                <li class="rounded-md bg-zinc-100 px-2 py-1 text-xs font-medium text-zinc-700 dark:bg-zinc-800 dark:text-zinc-200">
                  {item}
                </li>
              ))}
            </ul>
          </li>
        ))
      }
    </ul>
  </div>
</section>
