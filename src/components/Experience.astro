---
import { Icon } from "astro-icon/components";
import SectionHeading from "~/components/SectionHeading.astro";
import { experience } from "~/data/experience";

function formatMonth(value: string | null) {
  if (!value) return "Present";
  const [year, month] = value.split("-").map(Number);
  if (!year || !month) return value ?? "";
  const date = new Date(Date.UTC(year, month - 1, 1));
  return date.toLocaleString("en-US", { month: "short", year: "numeric", timeZone: "UTC" });
}
---

<section id="experience" class="border-t border-zinc-200/60 bg-zinc-50/60 py-20 sm:py-24 dark:border-zinc-800/60 dark:bg-zinc-900/30">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <SectionHeading
      eyebrow="Career"
      title="Experience & Education"
      description="Roles I've held and degrees I've earned along the way."
    />

    <ol class="relative ml-3 border-l border-zinc-200 pl-6 dark:border-zinc-800">
      {
        experience.map((item) => (
          <li class="group relative pb-10 last:pb-0">
            <span
              class="absolute -left-[38px] flex size-7 items-center justify-center rounded-full border border-zinc-200 bg-white text-accent-600 shadow-sm dark:border-zinc-800 dark:bg-zinc-950 dark:text-accent-400"
              aria-hidden="true"
            >
              <Icon
                name={item.kind === "education" ? "lucide:graduation-cap" : "lucide:briefcase"}
                class="size-3.5"
              />
            </span>

            <div class="rounded-xl border border-zinc-200 bg-white p-5 shadow-sm transition-colors hover:border-accent-300 dark:border-zinc-800 dark:bg-zinc-950 dark:hover:border-accent-700">
              <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
                <h3 class="text-lg font-semibold text-zinc-900 dark:text-white">
                  {item.role}
                </h3>
                <p class="text-sm tabular-nums text-zinc-500 dark:text-zinc-400">
                  {formatMonth(item.start)} — {formatMonth(item.end)}
                </p>
              </div>

              <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">
                {item.url ? (
                  <a
                    href={item.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="font-medium text-accent-700 hover:underline dark:text-accent-400"
                  >
                    {item.organization}
                  </a>
                ) : (
                  <span class="font-medium text-zinc-800 dark:text-zinc-200">{item.organization}</span>
                )}
                {item.location && <span class="text-zinc-400 dark:text-zinc-500"> · {item.location}</span>}
              </p>

              <ul class="mt-3 list-disc space-y-1.5 pl-5 text-sm text-zinc-700 marker:text-zinc-400 dark:text-zinc-300 dark:marker:text-zinc-600">
                {item.highlights.map((h) => (
                  <li>{h}</li>
                ))}
              </ul>

              {item.stack && item.stack.length > 0 && (
                <ul class="mt-4 flex flex-wrap gap-1.5">
                  {item.stack.map((s) => (
                    <li class="rounded-md bg-zinc-100 px-2 py-0.5 text-xs font-medium text-zinc-700 dark:bg-zinc-800 dark:text-zinc-300">
                      {s}
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>
