---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
}
const { eyebrow, title, description, align = "left" } = Astro.props;
const alignment = align === "center" ? "text-center mx-auto" : "text-left";
---

<header class={`mb-10 max-w-2xl ${alignment}`}>
  {
    eyebrow && (
      <p class="mb-2 text-sm font-medium uppercase tracking-widest text-accent-600 dark:text-accent-400">
        {eyebrow}
      </p>
    )
  }
  <h2 class="text-3xl font-bold tracking-tight text-zinc-900 sm:text-4xl dark:text-white">
    {title}
  </h2>
  {description && <p class="mt-3 text-base text-zinc-600 dark:text-zinc-400">{description}</p>}
</header>
