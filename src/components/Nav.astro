---
import { Icon } from "astro-icon/components";
import ThemeToggle from "~/components/ThemeToggle.astro";
import { site } from "~/data/site";

const navItems = [
  { href: "/#about", label: "About" },
  { href: "/#experience", label: "Experience" },
  { href: "/#skills", label: "Skills" },
  { href: "/#projects", label: "Projects" },
];

// On project detail pages we want anchors to point back to home.
const isHome = Astro.url.pathname === "/" || Astro.url.pathname === "";
---

<header
  class="sticky top-0 z-40 border-b border-zinc-200/60 bg-white/70 backdrop-blur-md supports-[backdrop-filter]:bg-white/60 dark:border-zinc-800/60 dark:bg-zinc-950/70 dark:supports-[backdrop-filter]:bg-zinc-950/60"
>
  <div class="mx-auto flex h-16 max-w-5xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <a
      href="/"
      class="group inline-flex items-center gap-2 font-semibold tracking-tight text-zinc-900 dark:text-white"
      aria-label={`${site.name} — home`}
    >
      <span
        class="inline-flex size-8 items-center justify-center rounded-md bg-accent-500 text-sm font-bold text-white shadow-sm transition-transform group-hover:scale-105"
      >
        JG
      </span>
      <span class="hidden sm:inline">{site.name}</span>
    </a>

    <nav aria-label="Primary" class="hidden items-center gap-1 md:flex">
      {
        navItems.map((item) => (
          <a
            href={isHome ? `#${item.href.split("#")[1]}` : item.href}
            class="rounded-md px-3 py-2 text-sm font-medium text-zinc-600 transition-colors hover:bg-zinc-100 hover:text-zinc-900 dark:text-zinc-300 dark:hover:bg-zinc-800 dark:hover:text-white"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-1">
      {
        site.resumeUrl && (
          <a
            href={site.resumeUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="hidden items-center gap-1.5 rounded-md bg-zinc-900 px-3 py-1.5 text-sm font-medium text-white shadow-sm transition-colors hover:bg-zinc-700 sm:inline-flex dark:bg-white dark:text-zinc-900 dark:hover:bg-zinc-200"
            aria-label="Open resume in a new tab"
          >
            <Icon name="lucide:file-text" class="size-4" aria-hidden="true" />
            Resume
          </a>
        )
      }
      <ThemeToggle />
      <button
        type="button"
        id="mobile-menu-button"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="inline-flex size-9 items-center justify-center rounded-md text-zinc-600 hover:bg-zinc-100 hover:text-zinc-900 md:hidden dark:text-zinc-300 dark:hover:bg-zinc-800 dark:hover:text-white"
      >
        <Icon name="lucide:menu" class="size-5" aria-hidden="true" />
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    hidden
    class="border-t border-zinc-200/60 bg-white md:hidden dark:border-zinc-800/60 dark:bg-zinc-950"
  >
    <nav aria-label="Mobile" class="mx-auto flex max-w-5xl flex-col gap-1 px-4 py-3 sm:px-6">
      {
        navItems.map((item) => (
          <a
            href={isHome ? `#${item.href.split("#")[1]}` : item.href}
            class="rounded-md px-3 py-2 text-base font-medium text-zinc-700 hover:bg-zinc-100 hover:text-zinc-900 dark:text-zinc-200 dark:hover:bg-zinc-800 dark:hover:text-white"
          >
            {item.label}
          </a>
        ))
      }
      {
        site.resumeUrl && (
          <a
            href={site.resumeUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-1 inline-flex items-center gap-1.5 rounded-md bg-zinc-900 px-3 py-2 text-base font-medium text-white sm:hidden dark:bg-white dark:text-zinc-900"
          >
            <Icon name="lucide:file-text" class="size-4" aria-hidden="true" />
            Resume
          </a>
        )
      }
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-button");
  const menu = document.getElementById("mobile-menu");

  btn?.addEventListener("click", () => {
    if (!menu) return;
    const expanded = btn.getAttribute("aria-expanded") === "true";
    btn.setAttribute("aria-expanded", String(!expanded));
    menu.hidden = expanded;
  });

  // Close after clicking any link inside the menu (anchor navigation).
  menu?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => {
      menu.hidden = true;
      btn?.setAttribute("aria-expanded", "false");
    })
  );
</script>
